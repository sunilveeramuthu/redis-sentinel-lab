#!/usr/bin/env bash

# git-branch-prune.sh — Interactive local branch pruning

# Compatible with bash 3.2+ (Git Bash on Windows ships bash 3.2)

# Skips: master, current branch

# Prompts one-by-one for your branches; auto-marks others’ branches as candidates

set -euo pipefail

# ── Current branch ──────────────────────────────────────────────────────────

# git branch –show-current requires Git 2.22+; fall back to rev-parse if needed

CURRENT_BRANCH=$(git branch –show-current 2>/dev/null || true)
if [[ -z “$CURRENT_BRANCH” ]]; then
CURRENT_BRANCH=$(git rev-parse –symbolic-full-name HEAD 2>/dev/null | sed ‘s|refs/heads/||’)
fi
if [[ -z “$CURRENT_BRANCH” ]]; then
echo “ERROR: Could not determine current branch. Are you in a git repo?”
exit 1
fi

# ── Identity ─────────────────────────────────────────────────────────────────

MY_EMAIL=$(git config user.email 2>/dev/null || true)
MY_NAME=$(git config user.name  2>/dev/null || true)

# ── Temp files ───────────────────────────────────────────────────────────────

# mktemp is unreliable on Git Bash; use TMPDIR/TEMP/TMP env vars with PID suffix

_tmpdir=”${TMPDIR:-${TEMP:-${TMP:-/tmp}}}”

# Strip trailing slash if present

_tmpdir=”${_tmpdir%/}”
_wt_tmpfile=”${_tmpdir}/git-prune-$$-wt.tmp”
_br_tmpfile=”${_tmpdir}/git-prune-$$-br.tmp”
trap ‘rm -f “$_wt_tmpfile” “$_br_tmpfile”’ EXIT

# ── Worktree map (bash 3.2: no associative arrays; use parallel indexed arrays)

# git worktree list default format: /path  <sha>  [branch]  or  (detached HEAD)

WORKTREE_BRANCHES=()
WORKTREE_PATHS=()

git worktree list > “$_wt_tmpfile” 2>/dev/null || true
while IFS= read -r line; do
_wt_path=$(echo “$line” | awk ‘{print $1}’)

# Extract branch name from [brackets]; sed works on bash 3.2 unlike grep -oP

_wt_branch=$(echo “$line” | sed -n ‘s/.*[([^]]*)].*/\1/p’)
if [[ -n “$_wt_branch” ]]; then
WORKTREE_BRANCHES+=(”$_wt_branch”)
WORKTREE_PATHS+=(”$_wt_path”)
fi
done < “$_wt_tmpfile”

worktree_path_for() {
local branch=”$1” i
for i in “${!WORKTREE_BRANCHES[@]}”; do
if [[ “${WORKTREE_BRANCHES[$i]}” == “$branch” ]]; then
echo “${WORKTREE_PATHS[$i]}”
return
fi
done
echo “”
}

# ── Helpers ──────────────────────────────────────────────────────────────────

is_protected() {
local branch=”$1”
[[ “$branch” == “master”          ]] && return 0
[[ “$branch” == “$CURRENT_BRANCH” ]] && return 0
return 1
}

is_mine() {
local branch=”$1” author_email author_name
author_email=$(git log -1 –format=”%ae” “$branch” 2>/dev/null || true)
author_name=$(git log -1  –format=”%an” “$branch” 2>/dev/null || true)
[[ -n “$MY_EMAIL” && “$author_email” == “$MY_EMAIL” ]] && return 0
[[ -n “$MY_NAME”  && “$author_name”  == “$MY_NAME”  ]] && return 0
return 1
}

# ── Header ───────────────────────────────────────────────────────────────────

echo “”
echo “=== Git Branch Pruner ===”
echo “Current branch : $CURRENT_BRANCH”
echo “Identity       : ${MY_NAME} <${MY_EMAIL}>”
echo “Protected      : master, $CURRENT_BRANCH”
echo “”

# ── Branch loop ──────────────────────────────────────────────────────────────

TO_DELETE=()
TO_DELETE_WORKTREES=()

git branch –format=’%(refname:short)’ > “$_br_tmpfile”

while IFS= read -r branch; do

# Trim leading whitespace and stray * markers

branch=”${branch#”${branch%%[![:space:]]*}”}”
branch=”${branch/* /}”

[[ -z “$branch” ]] && continue
is_protected “$branch” && continue

merged=””
if git merge-base –is-ancestor “$branch” master 2>/dev/null; then
merged=” [merged into master]”
fi

author_email=$(git log -1 –format=”%ae” “$branch” 2>/dev/null || echo “?”)
author_name=$(git log -1  –format=”%an” “$branch” 2>/dev/null || echo “?”)
last_date=$(git log -1    –format=”%ar” “$branch” 2>/dev/null || echo “?”)
wt_path=$(worktree_path_for “$branch”)

echo “Branch  : $branch”
echo “Author  : $author_name <$author_email>${merged}”
echo “Last    : $last_date”
[[ -n “$wt_path” ]] && echo “Worktree: $wt_path”

if is_mine “$branch”; then
if [[ -n “$wt_path” ]]; then
echo “Yours   : YES (checked out in worktree above)”
printf “  [k]eep both  [d]elete branch+worktree  [s]kip (default: keep) > “
else
echo “Yours   : YES – keep, delete, or skip?”
printf “  [k]eep  [d]elete  [s]kip (default: keep) > “
fi
read -r answer </dev/tty
case “$answer” in
d|D)
TO_DELETE+=(”$branch”)
[[ -n “$wt_path” ]] && TO_DELETE_WORKTREES+=(”$wt_path”)
echo “  -> Marked for deletion.”
;;
s|S) echo “  -> Skipped.” ;;
*)   echo “  -> Kept.” ;;
esac
else
if [[ -n “$wt_path” ]]; then
echo “Yours   : NO – marking branch + worktree as deletion candidates.”
TO_DELETE_WORKTREES+=(”$wt_path”)
else
echo “Yours   : NO – marking as deletion candidate.”
fi
TO_DELETE+=(”$branch”)
fi

echo “”
done < “$_br_tmpfile”

# ── Summary & confirmation ───────────────────────────────────────────────────

echo “===============================”
if [[ ${#TO_DELETE[@]} -eq 0 && ${#TO_DELETE_WORKTREES[@]} -eq 0 ]]; then
echo “Nothing to delete. You’re clean!”
exit 0
fi

if [[ ${#TO_DELETE[@]} -gt 0 ]]; then
echo “Branches marked for deletion (${#TO_DELETE[@]}):”
for b in “${TO_DELETE[@]}”; do
echo “  - $b”
done
fi

if [[ ${#TO_DELETE_WORKTREES[@]} -gt 0 ]]; then
echo “Worktrees marked for removal (${#TO_DELETE_WORKTREES[@]}):”
for w in “${TO_DELETE_WORKTREES[@]}”; do
echo “  - $w”
done
fi

echo “”
printf “Confirm deletion of all the above? [y/N] > “
read -r confirm </dev/tty

if [[ “$confirm” =~ ^[Yy]$ ]]; then

# Remove worktrees first — git won’t delete a branch checked out in a worktree

for w in “${TO_DELETE_WORKTREES[@]}”; do
git worktree remove –force “$w” && echo “Removed worktree: $w” || echo “Failed worktree:  $w”
done
for b in “${TO_DELETE[@]}”; do
git branch -D “$b” && echo “Deleted branch: $b” || echo “Failed branch:  $b”
done
echo “”
echo “Done.”
else
echo “Aborted. No branches or worktrees deleted.”
fi